{
  "name": "sg-github-action-plugin",
  "version": "1.0.0",
  "description": "GitHub Action to retrieve privileged passwords from One Identity Safeguard via the A2A API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "all": "npm run build && npm run package",
    "test": "jest --coverage"
  },
  "keywords": [
    "github-action",
    "safeguard",
    "one-identity",
    "a2a",
    "privileged-access"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/http-client": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
